{
    "diagnostic.checkCurrentLine": true,
    "diagnostic.refreshOnInsertMode": true,
    "diagnostic.virtualText": true,
    "diagnostic.virtualTextCurrentLineOnly": false,
    "coc.preferences.useQuickfixForLocations": true,
    "see_doc_at": "https://github.com/neoclide/coc.nvim/blob/master/data/schema.json",
    "rust-analyzer.updates.prompt": false,
    "clangd.path": "clangd-22",
    "clangd.arguments": ["--background-index=true", "--header-insertion=never"],
    "inlayHint.enable": false,
    "clangd.disableSnippetCompletion": true,
    "biome.bin": "/usr/bin/biome",
    "biome.requireConfiguration": false
}
